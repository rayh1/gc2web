---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a">;

const { href, class: className, ...props } = Astro.props;

const { pathname } = Astro.url;
const isActive = href === pathname || href === pathname.replace(/\/$/, "");
---

<a
  href={href}
  class:list={[
    "relative font-medium text-archive-muted transition-colors duration-200 hover:text-archive-accent dark:text-archive-dark-muted dark:hover:text-archive-dark-accent",
    className,
    {
      "text-archive-accent dark:text-archive-dark-accent after:absolute after:bottom-[-4px] after:left-0 after:h-0.5 after:w-full after:bg-archive-accent dark:after:bg-archive-dark-accent": isActive,
    },
  ]}
  {...props}
>
  <slot />
</a>
