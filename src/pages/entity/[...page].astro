---
import PageLayout from "../../layouts/PageLayout.astro";
import { type CollectionEntry, getCollection } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import PostList from "../../components/PostList.astro";
import { PAGINATION_POSTS_PER_PAGE } from "../../consts";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection("entity"));
  return paginate(posts, {
    pageSize: PAGINATION_POSTS_PER_PAGE,
  });
};

interface Props {
  page: Page<CollectionEntry<"entity">>;
};

const { page } = Astro.props;
---

<PageLayout
  title="Alle personen"
  description="Blader door alle personen in het familie-archief"
  currentContext={[
    { label: "Home", href: "/" },
    { label: "Alles" },
  ]}
>
  <h2>Alle personen</h2>
    {page.data.length === 0 && <p>Nog geen personen beschikbaar.</p>}
    {page.data.length > 0 && <PostList posts={page.data} />

    <div class="mt-8 grid w-full grid-cols-3 items-center gap-3 border-t border-archive-line/70 pt-6 text-sm dark:border-archive-dark-line/70">
      {
        page.url.prev ? (
          <a class="flex items-center gap-2 text-left text-archive-accent hover:text-archive-ink dark:text-archive-dark-accent dark:hover:text-archive-dark-ink" href={page.url.prev}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"
              />
            </svg>
            Vorige
          </a>
        ) : (
          <span />
        )
      }
      {
        page.url.current && (page.url.prev || page.url.next)? (
          <span class="text-center text-archive-muted dark:text-archive-dark-muted">Pagina {page.currentPage}</span>
        ) : (
          <span />
        )
      }
      {
        page.url.next ? (
          <a
            class="flex items-center justify-end gap-2 text-right text-archive-accent hover:text-archive-ink dark:text-archive-dark-accent dark:hover:text-archive-dark-ink"
            href={page.url.next}
          >
            Volgende
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
              />
            </svg>
          </a>
        ) : (
          <span />
        )
      }
  </div>
</PageLayout>
