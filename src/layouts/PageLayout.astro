---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  currentContext?: { label: string; href?: string }[];
  frontmatter?: {
    title: string;
  };
};

const { frontmatter, description, currentContext = [] } = Astro.props;
const title = frontmatter?.title || Astro.props.title;
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>

  <body class="page-shell min-h-screen flex flex-col">
    <Header currentContext={currentContext} />
    <main class="container flex-grow py-6 sm:py-8 lg:py-10">
      <div class="content-frame mx-auto max-w-6xl">
        <div class="prose prose-lg mx-auto max-w-none px-5 py-6 sm:px-8 sm:py-8 lg:px-12 lg:py-10 dark:prose-dark">
          <slot />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
