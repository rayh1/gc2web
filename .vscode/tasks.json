{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Init",
      "type": "shell",
      "command": "./init.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Refresh DevKit",
      "type": "shell",
      "command": "if [ -d /tmp/DevKit ]; then cd /tmp/DevKit && git pull; else git clone http://git.charm.nl:3000/Charm/DevKit /tmp/DevKit; fi && uv run /tmp/DevKit/install.py --target-dir /workspace/.github --skills --prompts --docs --skip-tooling-cli --no-vscode-settings",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Sync Dependencies",
      "type": "shell",
      "command": "uv sync",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Install Node Dependencies",
      "type": "shell",
      "command": "npm install",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run Dev",
      "type": "shell",
      "command": "npm run dev",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "npm test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
